# Profit Setu - Environment Variables Example
# Copy this file to .env.local and update the values as needed.

# --- SEO & Analytics ---
# Replace with your actual verification IDs from Google Search Console and Bing Webmaster Tools
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=google-site-verification-id
NEXT_PUBLIC_BING_SITE_VERIFICATION=bing-verification-id

# --- External Services (Optional) ---
# If you integrate a backend or paid APIs in the future, add them here
# APP_API_URL=https://api.profitsetu.com
# GOOGLE_TRANSLATE_API_KEY=your-api-key-if-using-v3

# --- Deployment ---
# The base URL of your site (used for canonical tags and sitemaps)
NEXT_PUBLIC_SITE_URL=https://profitsetu.com
